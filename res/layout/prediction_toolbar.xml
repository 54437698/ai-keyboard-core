<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/xml/android"
    android:id="@+id/prediction_toolbar"
    android:layout_width="match_parent"
    android:layout_height="45dp"
    android:orientation="horizontal"
    android:background="#1A1A1A" 
    android:gravity="center_vertical">

    <ImageButton
        android:id="@+id/btn_clipboard"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:src="@drawable/ic_clipboard"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Sovereign Clipboard" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/prediction_recycler"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:fadingEdgeLength="10dp"
        android:requiresFadingEdge="horizontal" />

    <ImageButton
        android:id="@+id/btn_mic"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:src="@drawable/ic_mic"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="NPU Voice Input" />

</LinearLayout>
