<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.jv.ai_keyboard">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:label="Joint Venture Keyboard"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher_foreground"
        android:supportsRtl="true">

        <activity 
            android:name=".SettingsActivity"
            android:label="JV Keyboard Settings"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
            </intent-filter>
        </activity>
        
        <service
            android:name=".JointVentureInputService"
            android:label="JV NPU Keyboard"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.inputmethod.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

    </application>
</manifest>
